# MedRock Payments API (Coupon Data)
MEDROCK_PAYMENTS_API_URL=https://medrock-payments-backend-production.onrender.com
MEDROCK_PAYMENTS_API_USER=
MEDROCK_PAYMENTS_API_PASS=

# Auth Service
NEXT_PUBLIC_AUTH_SERVICE_URL=https://auth.medrockpharmacy.com

# Supabase (for auth token validation)
NEXT_PUBLIC_SUPABASE_URL=
SUPABASE_SERVICE_ROLE_KEY=

# QuickBooks Online API
QUICKBOOKS_CLIENT_ID=
QUICKBOOKS_CLIENT_SECRET=
QUICKBOOKS_REDIRECT_URI=https://your-app.vercel.app/api/quickbooks/callback
QUICKBOOKS_ENVIRONMENT=sandbox
# Store tokens in Supabase - see amy_quickbooks_tokens table

# Development Mode - Skip authentication for local testing
# WARNING: Only use this in local development, NEVER in production!
# When enabled, all pages/routes are accessible without auth, and getCurrentUser() returns a mock admin user
# DEV_SKIP_AUTH=true

# AWS RDS (MedDotsPBI) - FIFO inventory tables
RDS_DATABASE_URL=postgresql://user:pass@host:5432/MedDotsPBI

# Google Drive — deposit slip upload portal (spec 2026-07-20)
# Same service account as MedRock Auth Host. Plain SA, no impersonation:
# medrock-loader@medrockdb.iam.gserviceaccount.com must be a Content Manager
# on the "MedRock Accounting" Shared Drive.
GOOGLE_SERVICE_ACCOUNT_KEY_BASE64=
DEPOSIT_SLIPS_FOLDER_ID=1VsPky7ENithxBcdXAu5yi5DNfZ7JaBZH
# HMAC key for upload-undo tokens. Generate:
#   node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
DEPOSIT_REMOVE_SECRET=

# Internal OCR gateway (Grant's Textract wrapper) — used by /api/deposits/ocr.
# Bearer secret: set the real value in .env.local / Vercel env, never commit it.
OCR_API_KEY=
# Optional: override the default gateway URL baked into ocrClient.ts.
OCR_API_URL=
