# See https://help.github.com/articles/ignoring-files/ for more about ignoring files.

# dependencies
/node_modules
/.pnp
.pnp.*
.yarn/*
!.yarn/patches
!.yarn/plugins
!.yarn/releases
!.yarn/versions

# testing
/coverage

# next.js
/.next/
/out/

# production
/build

# misc
.DS_Store
*.pem

# debug
npm-debug.log*
yarn-debug.log*
yarn-error.log*
.pnpm-debug.log*

# env files (can opt-in for committing if needed)
.env*
!.env.example

# vercel
.vercel

# typescript
*.tsbuildinfo
next-env.d.ts

# ramp-split-push preview output (contains cardholder PII)
scripts/ramp-split-push/out/

# amazon-enrich preview/live output (contains cardholder PII)
scripts/amazon-enrich/out/

# walmart-enrich persisted login session (auth cookies — never commit)
scripts/walmart-enrich/.wm-session/

.vercel
.env*
!.env.example
